rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      // Owner can update their own profile. Any signed-in user may update
      // only the rider rating aggregates (written by the customer after a ride).
      function ratingFieldsOnly() {
        return request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['rating', 'completedTrips', 'updatedAt']);
      }
      allow write: if isOwner(userId) || (isSignedIn() && ratingFieldsOnly());
    }

    match /rides/{rideId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /bids/{bidId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /chats/{chatId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn();
    }

    match /kyc_submissions/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /rider_kyc_submissions/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /ride_messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /ratings/{ratingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /group_messages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }
  }
}
